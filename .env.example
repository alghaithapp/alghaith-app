# =============================================================================
# Al-Ghaith App — Environment Variables (Master Reference)
# =============================================================================
# انسخ هذا الملف إلى .env وعبّئ القيم حسب بيئتك
# cp .env.example .env
# =============================================================================
#
# تنقسم المتغيرات إلى 4 مجموعات:
#   1. BACKEND  — خادم Express على Railway
#   2. WORKER   — Cloudflare Worker (المصادقة + رفع الملفات)
#   3. DASHBOARD — لوحة التحكم React/Vite
#   4. MOBILE   — تطبيق Flutter (تُمرر عبر --dart-define)
# =============================================================================

# ──────────────────────────────────────────────────────────────────────────────
# 1. BACKEND — خادم Express (backend/.env)
# ──────────────────────────────────────────────────────────────────────────────

# OTPIQ — خدمة إرسال رموز التحقق
OTPIQ_API_KEY=replace_with_your_otpiq_api_key
OTPIQ_BASE_URL=https://api.otpiq.com
OTPIQ_SMS_PROVIDER=sms
OTPIQ_WHATSAPP_PROVIDER=whatsapp-telegram-sms
OTP_TTL_MS=300000
OTP_LENGTH=6

# الجلسات — مفتاح توقيع HMAC-SHA256 لرموز الجلسة
SESSION_SECRET=replace_with_long_random_secret_here

# الخادم
PORT=3000
CORS_ALLOWED_ORIGINS=
RATE_LIMIT_GENERAL_MAX=120
RATE_LIMIT_OTP_SEND_MAX=5
RATE_LIMIT_OTP_VERIFY_MAX=10

# أرقام المشرفين (مفصولة بفواصل)
ADMIN_PHONES=+9647744009992

# Supabase — قاعدة البيانات الرئيسية
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Mapbox — الخرائط وحساب المسافات
MAPBOX_ACCESS_TOKEN=your_mapbox_secret_token_here
MAPBOX_PUBLIC_TOKEN=pk.your_mapbox_public_token_here

# Firebase — الإشعارات (JSON كامل كمفتاح واحد)
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ──────────────────────────────────────────────────────────────────────────────
# 2. CLOUDFLARE WORKER — متغيرات بيئة الـ Worker (wrangler.toml → dashboard)
# ──────────────────────────────────────────────────────────────────────────────

# OTPIQ_API_KEY  —  يُشارك مع الـ Backend (أعلاه)

# AUTH_KV — ربط KV Namespace (معرّف في wrangler.toml)
# CORS_ALLOWED_ORIGINS — يُشارك مع الـ Backend (أعلاه)
# SESSION_SECRET — يُشارك مع الـ Backend (يجب أن يكون متطابقاً)
# SUPABASE_URL — يُشارك مع الـ Backend
# SUPABASE_SERVICE_ROLE_KEY — يُشارك مع الـ Backend

# ──────────────────────────────────────────────────────────────────────────────
# 3. DASHBOARD (React/Vite) — متغيرات بيئة Vite (src/.env)
# ──────────────────────────────────────────────────────────────────────────────

# VITE_BACKEND_URL — رابط خادم الـ Backend (قيمة افتراضية: Railway URL)
# VITE_PHONE_AUTH_URL — رابط Cloudflare Worker للمصادقة

# ──────────────────────────────────────────────────────────────────────────────
# 4. MOBILE (Flutter) — تُمرر عبر --dart-define في Codemagic
# ──────────────────────────────────────────────────────────────────────────────

# DATABASE_BACKEND_BASE_URL  ← VITE_BACKEND_URL
# PHONE_AUTH_BASE_URL        ← VITE_PHONE_AUTH_URL
# MAPBOX_PUBLIC_TOKEN        ← MAPBOX_PUBLIC_TOKEN
