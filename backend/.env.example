# Backend Environment Variables
#
# المصدر الرئيسي لجميع المتغيرات: .env.example في جذر المشروع
# هذا الملف هو نسخة مختصرة لمتغيرات الـ Backend فقط.
#

OTPIQ_API_KEY=replace_with_your_otpiq_api_key
SESSION_SECRET=replace_with_long_random_secret
PORT=3000
CORS_ALLOWED_ORIGINS=
RATE_LIMIT_GENERAL_MAX=120
RATE_LIMIT_OTP_SEND_MAX=5
RATE_LIMIT_OTP_VERIFY_MAX=10
ADMIN_PHONES=
ENABLE_EMERGENCY_ROUTES=false
EMERGENCY_API_KEY=
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
MAPBOX_ACCESS_TOKEN=your_mapbox_access_token_here
MAPBOX_PUBLIC_TOKEN=pk.your_mapbox_public_token_here
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# اختياري — كاش Redis (BullMQ يستخدم نفس REDIS_URL إن وُجد)
REDIS_URL=
ENABLE_SERVER_WARMUP=true
CACHE_TTL_HOME_CATEGORIES_MS=300000
CACHE_TTL_MARKETPLACE_STATS_MS=180000
CACHE_TTL_STORE_LISTS_MS=120000
CACHE_TTL_CATALOG_MS=120000
CACHE_TTL_APP_POLICY_MS=600000
