OTPIQ_API_KEY=replace_with_your_otpiq_api_key
OTPIQ_BASE_URL=https://api.otpiq.com
OTPIQ_SMS_PROVIDER=sms
OTPIQ_WHATSAPP_PROVIDER=whatsapp-telegram-sms
OTP_TTL_MS=300000
OTP_LENGTH=6
SESSION_SECRET=replace_with_long_random_secret
PORT=3000
# Comma-separated browser origins (optional). Mobile apps usually send no Origin.
CORS_ALLOWED_ORIGINS=
# Optional rate-limit overrides
RATE_LIMIT_GENERAL_MAX=120
RATE_LIMIT_OTP_SEND_MAX=5
RATE_LIMIT_OTP_VERIFY_MAX=10
# Comma-separated admin phones (+964..., 07..., etc.)
ADMIN_PHONES=
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
MAPBOX_ACCESS_TOKEN=your_mapbox_access_token_here
