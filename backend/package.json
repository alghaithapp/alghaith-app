{
  "name": "alghaith-auth-backend",
  "version": "1.1.17",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --forceExit --detectOpenHandles",
    "test:watch": "node --experimental-vm-modules node_modules/.bin/jest --watch --forceExit",
    "setup-admin": "node scripts/grant_admin_access.js",
    "restore-primary-roles": "node scripts/restore_primary_roles.js",
    "egress-diagnostics": "node scripts/egress_diagnostics.js",
    "migrate-base64-images": "node scripts/migrate_base64_images_to_storage.js",
    "migrate-supabase-to-r2": "node scripts/migrate_supabase_storage_to_r2.js",
    "apply-chat-schema": "node scripts/apply_chat_messages_sql.js"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "@supabase/supabase-js": "^2.56.0",
    "agora-access-token": "^2.0.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "firebase-admin": "^13.4.0",
    "helmet": "^8.2.0",
    "winston": "^3.19.0",
    "ws": "^8.18.3"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "jest": "^30.4.2"
  }
}
