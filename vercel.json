{
  "version": 2,
  "framework": "vite",
  "buildCommand": "npm run build:web",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/admin/(.*)",
      "destination": "/admin/index.html"
    },
    {
      "source": "/((?!admin/).*)",
      "destination": "/$1"
    }
  ]
}
